{
  "expo": {
    "name": "Tatame",
    "slug": "ayon-tatame",
    "scheme": "vibecode",
    "version": "3.3",
    "orientation": "portrait",
    "icon": "./icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,

    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ayon.tatamebjj",
      "buildNumber": "11",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Tatame uses the microphone to record audio notes for training sessions.",
        "NSCameraUsageDescription": "Tatame uses the camera to capture photos inside the app before you publish them.",
        "NSPhotoLibraryUsageDescription": "Tatame accesses your photo library to let you choose media that appears in the app."
      }
    },

    "android": {
      "package": "com.ayon.tatamebjj",
      "versionCode": 11,
      "adaptiveIcon": {
        "foregroundImage": "./icon.png",
        "backgroundColor": "#000000"
      }
    },

    "plugins": [
      [
        "expo-router",
        {
          "root": "src/app"
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true
    },

    "extra": {
      "eas": {
        "projectId": "a1d2aa23-a70b-493d-ac39-afd834548deb"
      }
    }
  }
}